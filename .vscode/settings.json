{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.quickSuggestions": {
    // allow autocomplete for ArkType expressions like "string | num"
    // ref: https://arktype.io/docs/intro/setup#vscode
    "strings": "on"
  },

  // prioritize ArkType's "type" for autoimports
  "typescript.preferences.autoImportSpecifierExcludeRegexes": ["^(node:)?os$"],

  // Prettier
  "prettier.requireConfig": true,

  // ESLint
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],

  // Rust
  "rust-analyzer.linkedProjects": ["music/Cargo.toml"],
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },

  // Taplo
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.formatOnSave": true
  },

  // Typescript
  "typescript.tsserver.log": "verbose",

  // 楽曲データたちよう
  "json.schemas": [
    {
      "fileMatch": ["/music/data/artists_data.json"],
      "url": "./tools/artists_data.schema.json"
    },
    {
      "fileMatch": ["/music/data/input/*.json"],
      "url": "./tools/music.schema.json"
    }
  ],

  // spell checking
  "cSpell.words": [
    "appender",
    "arktype",
    "artistctl",
    "chrono",
    "cliplayer",
    "Deque",
    "dialoguer",
    "musictl",
    "reqwest",
    "rustls",
    "serde",
    "thiserror",
    "vitest",
    "walkdir"
  ]
}
