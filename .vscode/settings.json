{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.quickSuggestions": {
    // allow autocomplete for ArkType expressions like "string | num"
    // ref: https://arktype.io/docs/intro/setup#vscode
    "strings": "on"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  // prioritize ArkType's "type" for autoimports
  "js/ts.preferences.autoImportSpecifierExcludeRegexes": ["^(node:)?os$"],
  "files.associations": {
    "justfile": "plaintext"
  },

  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/target/**": true,
    "**/.angular/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/target/**": true,
    "**/.angular/**": true
  },

  // Prettier
  "prettier.requireConfig": true,

  // ESLint
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],

  // Taplo
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.formatOnSave": true
  },

  // Rust
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },

  // Typescript
  "js/ts.tsserver.log": "verbose",

  // 楽曲データたちよう
  "json.schemas": [
    {
      "fileMatch": ["metadata/artist/data/livers.json"],
      "url": "./tools/schema/livers.schema.json"
    },
    {
      "fileMatch": ["metadata/artist/data/official_channels.json"],
      "url": "./tools/schema/official_channels.schema.json"
    },
    {
      "fileMatch": ["metadata/tag/data/tags.json"],
      "url": "./tools/schema/video_tags.schema.json"
    },
    {
      "fileMatch": ["/music/data/input/*.json"],
      "url": "./tools/schema/music.schema.json"
    }
  ],

  // ref: https://github.com/davidanson/vscode-markdownlint/issues/422
  // TODO markdown lint消すか考える
  "json.schemaDownload.trustedDomains": {
    "https://raw.githubusercontent.com/DavidAnson/markdownlint/": true
  },

  // copilot
  //   chat
  "chat.tools.terminal.autoApprove": {
    "cd": true,
    "echo": true,
    "ls": true,
    "dir": true,
    "pwd": true,
    "cat": true,
    "head": true,
    "tail": true,
    "findstr": true,
    "wc": true,
    "tr": true,
    "cut": true,
    "cmp": true,
    "which": true,
    "basename": true,
    "dirname": true,
    "realpath": true,
    "readlink": true,
    "stat": true,
    "file": true,
    "od": true,
    "du": true,
    "df": true,
    "sleep": true,
    "nl": true,
    "grep": true,
    "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+status\\b/": true,
    "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+log\\b/": true,
    "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+show\\b/": true,
    "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+diff\\b/": true,
    "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+ls-files\\b/": true,
    "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+grep\\b/": true,
    "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+branch\\b/": true,
    "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+branch\\b.*\\s-(d|D|m|M|-delete|-force)\\b/": false,
    "Get-ChildItem": true,
    "Get-Content": true,
    "Get-Date": true,
    "Get-Random": true,
    "Get-Location": true,
    "Set-Location": true,
    "Write-Host": true,
    "Write-Output": true,
    "Out-String": true,
    "Split-Path": true,
    "Join-Path": true,
    "Start-Sleep": true,
    "Where-Object": true,
    "/^Select-[a-z0-9]/i": true,
    "/^Measure-[a-z0-9]/i": true,
    "/^Compare-[a-z0-9]/i": true,
    "/^Format-[a-z0-9]/i": true,
    "/^Sort-[a-z0-9]/i": true,
    "/^pnpm\\s+(ls|list|outdated|why|root|bin|doctor)\\b/": true,
    "/^pnpm\\s+licenses\\b/": true,
    "/^pnpm\\s+audit\\b(?!.*\\bfix\\b)/": true,
    "/^pnpm\\s+config\\s+(list|get)\\b/": true,
    "npm ci": true,
    "/^pnpm\\s+install\\s+--frozen-lockfile\\b/": true,
    "column": true,
    "/^column\\b.*\\s-c\\s+[0-9]{4,}/": false,
    "date": true,
    "/^date\\b.*\\s(-s|--set)\\b/": false,
    "find": true,
    "/^find\\b.*\\s-(delete|exec|execdir|fprint|fprintf|fls|ok|okdir)\\b/": false,
    "rg": true,
    "/^rg\\b.*\\s(--pre|--hostname-bin)\\b/": false,
    "sed": true,
    "/^sed\\b.*\\s(-[a-zA-Z]*(e|f)[a-zA-Z]*|--expression|--file)\\b/": false,
    "/^sed\\b.*s\\/.*\\/.*\\/[ew]/": false,
    "/^sed\\b.*;W/": false,
    "sort": true,
    "/^sort\\b.*\\s-(o|S)\\b/": false,
    "tree": true,
    "/^tree\\b.*\\s-o\\b/": false,
    "/^xxd$/": true,
    "/^xxd\\b(\\s+-\\S+)*\\s+[^-\\s]\\S*$/": true,
    "rm": false,
    "rmdir": false,
    "del": false,
    "Remove-Item": false,
    "ri": false,
    "rd": false,
    "erase": false,
    "dd": false,
    "kill": false,
    "ps": false,
    "top": false,
    "Stop-Process": false,
    "spps": false,
    "taskkill": false,
    "taskkill.exe": false,
    "curl": false,
    "wget": false,
    "Invoke-RestMethod": false,
    "Invoke-WebRequest": false,
    "irm": false,
    "iwr": false,
    "chmod": false,
    "chown": false,
    "Set-ItemProperty": false,
    "sp": false,
    "Set-Acl": false,
    "jq": false,
    "xargs": false,
    "eval": false,
    "Invoke-Expression": false,
    "iex": false,
    "/^cargo (build|check|test|fmt|clippy|run)\\b/": true,
    "/^sh -c \"\\. scripts/load_env\\.sh && echo X=\\$YOUTUBE_API_KEY\"$/": {
      "approve": true,
      "matchCommandLine": true
    }
  },

  // spell checking
  "cSpell.words": [
    "appender",
    "arktype",
    "artistctl",
    "chrono",
    "cliplayer",
    "Deque",
    "dialoguer",
    "musictl",
    "reqwest",
    "rustls",
    "serde",
    "thiserror",
    "vitest",
    "walkdir"
  ]
}
